  },
  "dependencies": {
    "@inertiajs/svelte": "^2.1.6",
    "@sveltejs/vite-plugin-svelte": "^3.1.2",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^22.10.2",
    "svelte": "^4.2.19",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.6.3",
    "vite": "^5.4.3"
  }
}
