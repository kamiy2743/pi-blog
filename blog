#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

usage() {
  cat <<'EOF'
usage:
  ./blog {dev|prd} {up|down|restart|recreate} [docker compose args...]
  ./blog {dev|prd} [docker compose args...]
  ./blog {dev|prd} mysql [mysql args...]
  ./blog {dev|prd} migrate {up|down|fresh|status} [goose args...]
  ./blog {dev|prd} seed <seed_name>
  ./blog sqlc [sqlc args...]
EOF
}

run_compose() {
  local env="$1"
  shift

  local compose_file="$SCRIPT_DIR/docker-compose.${env}.yml"
  docker compose -p "blog-${env}" -f "$compose_file" "$@"
}

get_secret_value() {
  local env="$1"
  local secret_name="$2"
  tr -d '\r\n' <"$SCRIPT_DIR/secrets/$env/$secret_name"
}

run_mysql() {
  local env="$1"
  shift

  local db_user="$(get_secret_value "$env" mysql_user)"
  local db_password="$(get_secret_value "$env" mysql_user_password)"

  run_compose "$env" exec mysql \
    mysql "-u${db_user}" "-p${db_password}" \
    "$@"
}

run_goose() {
  local env="$1"
  shift

  local db_user="$(get_secret_value "$env" mysql_user)"
  local db_password="$(get_secret_value "$env" mysql_user_password)"

  docker run --rm \
    --entrypoint goose \
    --network "blog-${env}_private" \
    -v "$SCRIPT_DIR/backend/db/migrations/:/migrations/:ro" \
    "ghcr.io/kukymbr/goose-docker:3.27.0" \
    mysql \
    "${db_user}:${db_password}@tcp(mysql:3306)/blog?parseTime=true" \
    -dir /migrations/ \
    "$@"
}

run_sqlc() {
  local command="$1"
  shift

  local args=()

  case "$command" in
    generate)
      args+=("$command")
      ;;
    *)
      args+=("$command")
      ;;
  esac

  args+=("$@")

  docker run --rm \
    -v "$SCRIPT_DIR/backend/:/src/" \
    -w /src/ \
    "sqlc/sqlc:latest" \
    "${args[@]}"
}

migrate() {
  local env="$1"
  local action="$2"
  shift 2

  case "$action" in
    up|down|status)
      run_goose "$env" "$action" "$@"
      ;;
    fresh)
      run_goose "$env" reset "$@"
      run_goose "$env" up
      ;;
    *)
      echo "unsupported migrate action: $action" >&2
      exit 1
      ;;
  esac
}

seed() {
  local env="$1"
  local db_user="$(get_secret_value "$env" mysql_user)"
  local db_password="$(get_secret_value "$env" mysql_user_password)"
  local seed="$2"
  local seed_file="$SCRIPT_DIR/backend/db/seeds/$seed.sql"

  if [[ ! -f "$seed_file" ]]; then
    echo "seed file not found: $seed_file" >&2
    exit 1
  fi

    run_compose "$env" exec -T mysql \
      mysql "-u${db_user}" "-p${db_password}" \
      blog < "$seed_file"
}

main() {
  if [[ $# -lt 1 ]]; then
    usage
    exit 1
  fi

  local command="$1"
  shift

  case "$command" in
    sqlc)
      if [[ $# -lt 1 ]]; then
        usage
        exit 1
      fi
      run_sqlc "$@"
      ;;
    dev|prd)
      local env="$command"

      if [[ $# -lt 1 ]]; then
        usage
        exit 1
      fi

      local action="$1"
      shift

      case "$action" in
        up)
          run_compose "$env" up -d --build "$@"
          ;;
        down)
          run_compose "$env" down "$@"
          ;;
        restart)
          run_compose "$env" restart "$@"
          ;;
        recreate)
          run_compose "$env" down "$@"
          run_compose "$env" up -d --build "$@"
          ;;
        mysql)
          run_mysql "$env" "$@"
          ;;
        migrate)
          if [[ $# -lt 1 ]]; then
            usage
            exit 1
          fi
          migrate "$env" "$@"
          ;;
        seed)
          if [[ $# -lt 1 ]]; then
            usage
            exit 1
          fi
          seed "$env" "$1"
          ;;
        *)
          run_compose "$env" "$action" "$@"
          ;;
      esac
      ;;
    *)
      usage
      exit 1
      ;;
  esac
}

main "$@"
