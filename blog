#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
BLOGCMD_RELATIVE_PATH="blogcmd/bin/blogcmd"
BLOGCMD="$SCRIPT_DIR/$BLOGCMD_RELATIVE_PATH"
BUILDCMD="buildcmd"

if [[ "${1:-}" == "$BUILDCMD" ]]; then
  if ! command -v go >/dev/null 2>&1; then
    echo "go が見つかりません。blogcmd をビルドできません。" >&2
    exit 1
  fi

  mkdir -p "$SCRIPT_DIR/blogcmd/bin"
  (cd "$SCRIPT_DIR/blogcmd" && go build -o "$BLOGCMD" ./cmd/app)
  exit 0
fi

if [[ ! -x "$BLOGCMD" ]]; then
  echo "${BLOGCMD_RELATIVE_PATH} が見つかりません。./blog ${BUILDCMD} を実行してください。" >&2
  exit 1
fi

exec "$BLOGCMD" "$@"
