#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

usage() {
  cat <<'EOF'
使い方:
  ./blog {dev|prd} {up|down|restart|recreate} [docker compose args...]
  ./blog {dev|prd} [docker compose args...]
  ./blog {dev|prd} mysql [mysql args...]
  ./blog ent generate
  ./blog {dev|prd} migrate {up|down|refresh}
  ./blog {dev|prd} seed <seed_name>
EOF
}

run_compose() {
  local env="$1"
  shift

  local compose_file="$SCRIPT_DIR/docker-compose.${env}.yml"
  docker compose -p "blog-${env}" -f "$compose_file" "$@"
}

get_secret_value() {
  local env="$1"
  local secret_name="$2"
  tr -d '\r\n' <"$SCRIPT_DIR/secrets/$env/$secret_name"
}

run_mysql() {
  local env="$1"
  shift

  local db_user="$(get_secret_value "$env" mysql_user)"
  local db_password="$(get_secret_value "$env" mysql_user_password)"

  run_compose "$env" exec mysql \
    mysql "-u${db_user}" "-p${db_password}" \
    "$@"
}

run_ent() {
  local command="$1"
  shift

  case "$command" in
    generate)
      (cd "$SCRIPT_DIR/backend" && /usr/local/go/bin/go generate ./internal/ent "$@")
      ;;
    *)
      echo "未対応の ent コマンドです: $command" >&2
      exit 1
      ;;
  esac
}

run_migrate() {
  local env="$1"
  local command="$2"
  local image_tag="blog-migration:${env}"

  case "$command" in
    up|down|refresh)
      docker build \
        -f "$SCRIPT_DIR/backend/Dockerfile.migration" \
        -t "$image_tag" \
        "$SCRIPT_DIR/backend"
      docker run --rm \
        --network "blog-${env}_private" \
        --env-file "$SCRIPT_DIR/backend/.env.${env}" \
        --mount "type=bind,src="$SCRIPT_DIR/secrets/${env}",dst=/run/secrets,readonly" \
        "$image_tag" "$command"
      ;;
    *)
      echo "未対応の migrate コマンドです: $command" >&2
      exit 1
      ;;
  esac
}

run_seed() {
  local env="$1"
  local db_user="$(get_secret_value "$env" mysql_user)"
  local db_password="$(get_secret_value "$env" mysql_user_password)"
  local seed="$2"
  local seed_file="$SCRIPT_DIR/backend/db/seeds/$seed.sql"

  if [[ ! -f "$seed_file" ]]; then
    echo "seed ファイルが見つかりません: $seed_file" >&2
    exit 1
  fi

    run_compose "$env" exec -T mysql \
      mysql "-u${db_user}" "-p${db_password}" \
      blog < "$seed_file"
}

main() {
  if [[ $# -lt 1 ]]; then
    usage
    exit 1
  fi

  local command="$1"
  shift

  case "$command" in
    ent)
      if [[ $# -lt 1 ]]; then
        usage
        exit 1
      fi
      run_ent "$@"
      ;;
    dev|prd)
      local env="$command"

      if [[ $# -lt 1 ]]; then
        usage
        exit 1
      fi

      local action="$1"
      shift

      case "$action" in
        up)
          run_compose "$env" up -d --build "$@"
          ;;
        down)
          run_compose "$env" down "$@"
          ;;
        restart)
          run_compose "$env" restart "$@"
          ;;
        recreate)
          run_compose "$env" down "$@"
          run_compose "$env" up -d --build "$@"
          ;;
        mysql)
          run_mysql "$env" "$@"
          ;;
        migrate)
          if [[ $# -lt 1 ]]; then
            usage
            exit 1
          fi
          run_migrate "$env" "$1"
          ;;
        seed)
          if [[ $# -lt 1 ]]; then
            usage
            exit 1
          fi
          run_seed "$env" "$1"
          ;;
        *)
          run_compose "$env" "$action" "$@"
          ;;
      esac
      ;;
    *)
      usage
      exit 1
      ;;
  esac
}

main "$@"
