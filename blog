#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

usage() {
  cat <<'EOF'
使い方:
  ./blog {dev|prd} {up|down|restart|recreate} [docker compose args...]
  ./blog {dev|prd} [docker compose args...]
  ./blog {dev|prd} mysql [mysql args...]
  ./blog ent generate
  ./blog back fmt
  ./blog back mod tidy
  ./blog back test [backend path]
  ./blog front install
  ./blog {dev|prd} migrate {up|down|refresh}
  ./blog {dev|prd} seed <seed_name>
EOF
}

run_compose() {
  local env="$1"
  shift

  local compose_file="$SCRIPT_DIR/docker-compose.${env}.yml"
  docker compose -p "blog-${env}" -f "$compose_file" "$@"
}

get_secret_value() {
  local env="$1"
  local secret_name="$2"
  tr -d '\r\n' <"$SCRIPT_DIR/secrets/$env/$secret_name"
}

run_mysql() {
  local env="$1"
  shift

  local db_user="$(get_secret_value "$env" mysql_user)"
  local db_password="$(get_secret_value "$env" mysql_user_password)"

  run_compose "$env" exec mysql \
    mysql "-u${db_user}" "-p${db_password}" \
    "$@"
}

run_ent() {
  local command="$1"
  shift

  case "$command" in
    generate)
      (cd "$SCRIPT_DIR/backend" && /usr/local/go/bin/go generate ./internal/db/ent "$@")
      ;;
    *)
      echo "未対応の ent コマンドです: $command" >&2
      exit 1
      ;;
  esac
}

run_go() {
  local command="$1"
  shift

  case "$command" in
    fmt)
      local -a go_roots=()
      local root
      local -a go_files=()

      for root in "$SCRIPT_DIR/backend" "$SCRIPT_DIR/mcp"; do
        if [[ -d "$root" ]]; then
          go_roots+=("$root")
        fi
      done

      if [[ ${#go_roots[@]} -eq 0 ]]; then
        echo "整形対象の Go ディレクトリがありません" >&2
        return 0
      fi

      mapfile -t go_files < <(find "${go_roots[@]}" -type f -name '*.go' | sort)
      if [[ ${#go_files[@]} -eq 0 ]]; then
        echo "整形対象の Go ファイルがありません" >&2
        return 0
      fi
      /usr/local/go/bin/gofmt -w "${go_files[@]}"
      ;;
    mod)
      local subcommand="${1:-}"
      shift || true

      case "$subcommand" in
        tidy)
          local -a go_mod_dirs=()
          local mod_dir

          for mod_dir in "$SCRIPT_DIR/backend" "$SCRIPT_DIR/mcp"; do
            if [[ -f "$mod_dir/go.mod" ]]; then
              go_mod_dirs+=("$mod_dir")
            fi
          done

          if [[ ${#go_mod_dirs[@]} -eq 0 ]]; then
            echo "go.mod を持つ対象ディレクトリがありません" >&2
            return 0
          fi

          for mod_dir in "${go_mod_dirs[@]}"; do
            (cd "$mod_dir" && /usr/local/go/bin/go mod tidy "$@")
          done
          ;;
        *)
          echo "未対応の back mod コマンドです: $subcommand" >&2
          exit 1
          ;;
      esac
      ;;
    test)
      local backend_dir="$SCRIPT_DIR/backend"
      local target="./..."

      if [[ $# -ge 1 ]]; then
        target="$1"

        if [[ -f "$target" ]]; then
          echo "back test は Go package 単位で実行してください。ファイル指定は未対応です: $target" >&2
          exit 1
        fi

        if [[ "$target" == "$backend_dir" ]]; then
          target="."
        elif [[ "$target" == "$backend_dir"/* ]]; then
          target=".${target#"$backend_dir"}"
        fi
      fi

      run_compose dev up -d --build go-test
      run_compose dev exec -T go-test bash -lc '
        set -euo pipefail

        cd /app
        go_bin=/usr/local/go/bin/go

        mapfile -t test_packages < <(
          "$go_bin" list -f '"'"'{{if or (gt (len .TestGoFiles) 0) (gt (len .XTestGoFiles) 0)}}{{.ImportPath}}{{end}}'"'"' "$1" |
            sed "/^$/d"
        )

        if [[ ${#test_packages[@]} -eq 0 ]]; then
          echo "テスト対象の package がありません: $1" >&2
          exit 0
        fi

        "$go_bin" test -mod=readonly -p 1 "${test_packages[@]}"
      ' bash "$target"
      ;;
    *)
      echo "未対応の back コマンドです: $command" >&2
      exit 1
      ;;
  esac
}

run_front() {
  local command="$1"
  shift

  case "$command" in
    install)
      (cd "$SCRIPT_DIR/frontend" && npm install "$@")
      ;;
    *)
      echo "未対応の front コマンドです: $command" >&2
      exit 1
      ;;
  esac
}

run_migrate() {
  local env="$1"
  local command="$2"
  local image_tag="blog-migration:${env}"

  case "$command" in
    up|down|refresh)
      docker build \
        -f "$SCRIPT_DIR/backend/Dockerfile.migration" \
        -t "$image_tag" \
        "$SCRIPT_DIR/backend"
      docker run --rm \
        --network "blog-${env}_private" \
        --env-file "$SCRIPT_DIR/backend/.env.${env}" \
        --mount "type=bind,src="$SCRIPT_DIR/secrets/${env}",dst=/run/secrets,readonly" \
        "$image_tag" "$command"
      ;;
    *)
      echo "未対応の migrate コマンドです: $command" >&2
      exit 1
      ;;
  esac
}

run_seed() {
  local env="$1"
  local seed="$2"
  local image_tag="blog-seed:${env}"

  docker build \
    -f "$SCRIPT_DIR/backend/Dockerfile.seed" \
    -t "$image_tag" \
    "$SCRIPT_DIR/backend"
  docker run --rm \
    --network "blog-${env}_private" \
    --env-file "$SCRIPT_DIR/backend/.env.${env}" \
    --mount "type=bind,src=$SCRIPT_DIR/secrets/${env},dst=/run/secrets,readonly" \
    "$image_tag" "$seed"
}

main() {
  if [[ $# -lt 1 ]]; then
    usage
    exit 1
  fi

  local command="$1"
  shift

  case "$command" in
    ent)
      if [[ $# -lt 1 ]]; then
        usage
        exit 1
      fi
      run_ent "$@"
      ;;
    back)
      if [[ $# -lt 1 ]]; then
        usage
        exit 1
      fi
      run_go "$@"
      ;;
    front)
      if [[ $# -lt 1 ]]; then
        usage
        exit 1
      fi
      run_front "$@"
      ;;
    dev|prd)
      local env="$command"

      if [[ $# -lt 1 ]]; then
        usage
        exit 1
      fi

      local action="$1"
      shift

      case "$action" in
        up)
          run_compose "$env" up -d --build "$@"
          ;;
        down)
          run_compose "$env" down "$@"
          ;;
        restart)
          run_compose "$env" restart "$@"
          ;;
        recreate)
          run_compose "$env" down "$@"
          run_compose "$env" up -d --build "$@"
          ;;
        mysql)
          run_mysql "$env" "$@"
          ;;
        migrate)
          if [[ $# -lt 1 ]]; then
            usage
            exit 1
          fi
          run_migrate "$env" "$1"
          ;;
        seed)
          if [[ $# -lt 1 ]]; then
            usage
            exit 1
          fi
          run_seed "$env" "$1"
          ;;
        *)
          run_compose "$env" "$action" "$@"
          ;;
      esac
      ;;
    *)
      usage
      exit 1
      ;;
  esac
}

main "$@"
